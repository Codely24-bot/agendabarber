{
  "name": "agendabarber",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "backend",
    "frontend",
    "chatbot"
  ],
  "scripts": {
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "chatbot:start": "npm --prefix chatbot start",
    "chatbot:install": "npm --prefix chatbot install"
  }
}
